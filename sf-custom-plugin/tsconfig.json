{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "typeRoots": ["./node_modules/@figma", "./node_modules/@types"]
  },
  "include": ["src/**/*.ts"]
}
